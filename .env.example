# PORPASS environment configuration
# Copy this file to `.env` and fill in real values. The .env file is gitignored
# and must never be committed.

# ── Application ────────────────────────────────────────────────────────────
# APP_ENV: one of "production", "development", or "development-local".
# When APP_ENV starts with "development", PHP error display is enabled.
APP_ENV=development-local
APP_DEBUG=true
# Base URL the app is served from. Used in transactional emails for building
# absolute links (verification, password reset, etc.).
APP_URL=http://porpass.local

# ── Database (MariaDB / MySQL) ─────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=porpass_dev
DB_USERNAME=porpass
DB_PASSWORD=change-me

# ── Outbound mail (PHPMailer / SMTP) ───────────────────────────────────────
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=your_smtp_username
MAIL_PASSWORD=your_smtp_password
MAIL_FROM=noreply@porpass.example.org
MAIL_FROM_NAME=PORPASS

# ── Processing subsystem ───────────────────────────────────────────────────
# Absolute path to the porpass-storage mount. The web reads GRaSP schema
# artifacts from {PORPASS_STORAGE_PATH}/schemas/ and writes per-job config +
# results under {PORPASS_STORAGE_PATH}/processing/{user_id}/{job_id}/.
# Leave empty in dev to fall back to bundled fixtures under
# private/fixtures/schemas/.
PORPASS_STORAGE_PATH=
